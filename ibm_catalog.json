            "short_description": "Automated Disaster Recovery for IBM Cloud VPC Virtual Server Instances using Terraform, Ansible, ArgoCD, and GitHub Actions.",
            "long_description": "This deployable architecture implements a fully automated Disaster Recovery (DR) solution for IBM Cloud VPC Virtual Server Instances (VSIs) using a modern Terraform + GitOps stack.\n\nThe architecture provisions warm standby VSIs in a secondary IBM Cloud region and orchestrates failover through a GitHub Actions pipeline. Terraform manages infrastructure-as-code and stores state in IBM Cloud Object Storage. Ansible configures DR VSIs post-provisioning and activates workloads during a failover event. ArgoCD provides GitOps-driven application synchronization to ensure the DR environment stays in sync with the primary. Automated health checks continuously monitor the primary region and trigger the failover pipeline when thresholds are breached.\n\nThis is the approach used by many hyperscalers for internal DR and is fully cloud-native, multi-region, and auditable through Git history.",
            "offering_docs_url": "https://raw.githubusercontent.com/IBM/dr-automation-vpc-vsi/main/README.md",
            "offering_icon_url": "data:image/svg+xml;base64,",
            "module_info": {},
            "support_details": "Community supported. No official IBM support is given for this demonstration deployable architecture.",
            "flavors": [
                {
                    "label": "Standard",
                    "name": "standard",
                    "install_type": "fullstack",
                    "working_directory": "solutions/dr-automation",
                    "usage_template": "module \"dr_automation\" {\n  source                        = \"https://cm.globalcatalog.cloud.ibm.com/api/v1-beta/offering/source//${{workingDirectory}}?archive=tgz&catalogID=${{catalogID}}&flavor=${{flavor}}&kind=${{kind}}&name=${{name}}&version=${{version}}\"\n  ibmcloud_api_key              = var.ibmcloud_api_key\n  prefix                        = var.prefix\n  primary_region                = var.primary_region\n  dr_region                     = var.dr_region\n  primary_vpc_name              = var.primary_vpc_name\n  ssh_public_key                = var.ssh_public_key\n  ssh_private_key               = var.ssh_private_key\n  dr_vsi_count                  = var.dr_vsi_count\n  rto_minutes                   = var.rto_minutes\n  rpo_minutes                   = var.rpo_minutes\n}\n\n",
                    "scripts": [
                        {
                            "type": "ansible",
                            "short_description": "Configure DR VSIs with GitOps toolchain (ArgoCD, Ansible agent, health checks)",
                            "path": "solutions/dr-automation/scripts/deploy-post-ansible-playbook.yaml",
                            "stage": "post",
                            "action": "deploy"
                        }
                    ],
                    "compliance": {
