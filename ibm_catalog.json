                        "diagrams": [
                            {
                                "diagram": {
                                    "caption": "DR Automation - Terraform + GitOps Architecture",
                                    "url": "https://raw.githubusercontent.com/IBM/dr-automation-vpc-vsi/main/reference-architecture/dr-automation-arch.svg",
                                    "metadata": []
                                },
                                "description": "This architecture deploys warm standby VSIs in a secondary IBM Cloud VPC region. A GitHub Actions pipeline orchestrates the full DR lifecycle: Terraform provisions and manages DR infrastructure using state stored in IBM Cloud Object Storage; Ansible configures VSIs and activates workloads on failover; ArgoCD syncs application manifests from Git to keep DR in lockstep with production. Automated health checks run at the configured RPO interval and trigger failover when the primary region becomes unreachable. The entire DR workflow is auditable through Git history and IBM Cloud Activity Tracker."
